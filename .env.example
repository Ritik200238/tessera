# Tessera — environment template (TDD §20.1)
# Copy to .env and fill in values. .env is gitignored.

# Network
NEXT_PUBLIC_CHAIN_ENV=testnet          # testnet | fallback (arb-sepolia) | local
RPC_URL_TESTNET=https://...            # used by deploy + agent
RPC_URL_FALLBACK=https://...arbitrum-sepolia...
RPC_URL_LOCAL=http://127.0.0.1:8545

# Contract addresses are NOT in .env — they live in shared/addresses/<env>.json

# Agent
AGENT_PRIVATE_KEY=0x...                # hot key, testnet only — never commit
AGENT_POLL_INTERVAL_MS=10000
AGENT_LOG_DIR=./logs
AGENT_DB_PATH=./.data/state.sqlite
AGENT_HTTP_PORT=8787
AGENT_ADMIN_SECRET=...                 # gates POST /config

# LLM
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-haiku-4-5

# Owner / deployer
DEPLOYER_PRIVATE_KEY=0x...             # testnet only — separate from AGENT key

# Observability
SENTRY_DSN=...                         # optional
DISCORD_WEBHOOK_URL=...                # optional

# Tessera Risk Agent — environment template
# Copy to `.env` and fill in. NEVER commit `.env`.

# --- Network ---
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=412346
VAULT_ADDRESS=0x0000000000000000000000000000000000000000
USDC_ADDRESS=0x0000000000000000000000000000000000000000

# --- Agent ---
# Hot wallet — testnet only. Mainnet uses KMS (TDD §8.1).
AGENT_PRIVATE_KEY=0x1111111111111111111111111111111111111111111111111111111111111111
AGENT_POLL_INTERVAL_MS=10000
AGENT_LOG_DIR=./logs
AGENT_DB_PATH=./.data/state.sqlite
AGENT_HTTP_PORT=8787
AGENT_ADMIN_SECRET=change-me-to-a-long-random-string
AGENT_LOG_RETENTION_DAYS=7

# --- LLM (TDD §20.3) ---
# Alert copy is phrased by an LLM; the deterministic core never depends on it.
# Primary: open models on NVIDIA NIM (OpenAI-compatible). Ordered fallback chain;
# each attempt is bounded by NIM_TIMEOUT_MS so a cold model never blocks a tick.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODELS=meta/llama-3.3-70b-instruct,qwen/qwen3.5-122b-a10b,moonshotai/kimi-k2.6
NIM_TIMEOUT_MS=12000
# Cross-provider fallback if every NIM model fails. Also used for NL /config parsing.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5

# --- Observability ---
LOG_LEVEL=info
NODE_ENV=development

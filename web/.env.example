# Network selection — testnet (Robinhood Chain) | fallback (Arbitrum Sepolia) | local
NEXT_PUBLIC_CHAIN_ENV=testnet

# Custom RPC for the active chain (Robinhood Chain ID/RPC not yet final — see lib/chain.ts)
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_RPC_CHAIN_ID=
NEXT_PUBLIC_RPC_CHAIN_NAME=Robinhood Chain Testnet

# WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Risk agent HTTP server (TDD §4.7)
NEXT_PUBLIC_AGENT_URL=http://localhost:8787

# Admin gating for /admin route (TDD §5.2)
NEXT_PUBLIC_ADMIN_ADDRESS=
NEXT_PUBLIC_OWNER_ADDRESS=

# Server-only — never expose to the browser
AGENT_ADMIN_SECRET=
